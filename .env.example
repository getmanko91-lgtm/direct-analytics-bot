# OAuth-токен Яндекс.Директ (https://oauth.yandex.ru/)
YANDEX_DIRECT_TOKEN=

# Опционально: отдельный OAuth-токен для API Метрики (scope metrika:read)
YANDEX_METRIKA_TOKEN=

# Telegram Bot API (создайте бота через @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Веб-интерфейс
SECRET_KEY=change-me-to-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
WEB_HOST=127.0.0.1
WEB_PORT=8080

# Расписание (встроенный планировщик веб-сервиса)
REPORT_TIME=09:00
TIMEZONE=Europe/Moscow

# НДС для расчёта CPA (22% с 2026)
VAT_RATE=0.22

# На сервере с HTTPS: SESSION_HTTPS_ONLY=true (cookie только по HTTPS)
SESSION_HTTPS_ONLY=false
