# OAuth-токен Яндекс.Директ (https://oauth.yandex.ru/)
YANDEX_DIRECT_TOKEN=

# Опционально: отдельный OAuth-токен для API Метрики (scope metrika:read).
YANDEX_METRIKA_TOKEN=

# --- Telegram (опционально, если используете Telegram) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_PROXY=socks5://user:pass@host:1080

# --- MAX (мессенджер) — dev.max.ru ---
MAX_BOT_TOKEN=
MAX_CHAT_ID=

# Куда отправлять отчёты по умолчанию: telegram | max | both
# (можно переопределить в веб-настройках)
REPORT_CHANNEL=max

# Веб-интерфейс
SECRET_KEY=change-me-to-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
WEB_HOST=127.0.0.1
WEB_PORT=8080

REPORT_TIME=09:00
TIMEZONE=Europe/Moscow
VAT_RATE=0.22
SESSION_HTTPS_ONLY=false
